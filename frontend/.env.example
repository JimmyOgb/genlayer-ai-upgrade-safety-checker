# GenLayer RPC endpoint.
# Default points at the hosted GenLayer Studio backend — use this for
# studionet, or point at a local `genlayer up` instance for localnet.
VITE_GENLAYER_RPC_URL=https://studio.genlayer.com/api

# Address of your deployed UpgradeSafetyChecker instance.
# Reference deployment used during development of this dashboard:
# 0x222201F7742dac79Aa37cd6aC5242F65eb303745
VITE_CONTRACT_ADDRESS=0x222201F7742dac79Aa37cd6aC5242F65eb303745
